# Copy to .env.local for local development (never commit .env.local)

# ── Auth (local + Netlify) ──────────────────────────────────────────────
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Local SQLite (your Mac only — npm run dev) ─────────────────────────
DATABASE_PATH=data/tile-logistics.db
UPLOAD_ROOT=data/uploads

# Use local file for `npm run dev`. Netlify must NOT set this (uses Turso).
USE_LOCAL_DATABASE=true

# ── Turso (Netlify production + optional npm run dev:turso) ───────────
# Get URL:  turso db show tile-logistics-prod --url
# Get token: turso db tokens create tile-logistics-prod
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=your-token

# On Netlify → Site settings → Environment variables, set ONLY:
#   TURSO_DATABASE_URL, TURSO_AUTH_TOKEN, AUTH_SECRET, ADMIN_USERNAME, ADMIN_PASSWORD
# Do NOT set USE_LOCAL_DATABASE on Netlify.
